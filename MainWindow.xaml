<Window x:Class="phonic.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:phonic.Models"
        Title="Phonic"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#0F172A">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                Padding="48,22"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1E3A5F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <!-- Slider track: filled (left of thumb) -->
        <Style x:Key="SliderDecreaseRepeat" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="#3B82F6" Height="6" CornerRadius="3,0,0,3"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slider track: empty (right of thumb) -->
        <Style x:Key="SliderIncreaseRepeat" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="#334155" Height="6" CornerRadius="0,3,3,0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VolumeSliderStyle" TargetType="Slider">
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center" Height="20">
                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource SliderDecreaseRepeat}" Command="Slider.DecreaseLarge"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb IsTabStop="False">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="White" Width="20" Height="20"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource SliderIncreaseRepeat}" Command="Slider.IncreaseLarge"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="80,60,80,32">
            <TextBlock Text="Phonic"
                       FontSize="52"
                       FontWeight="Bold"
                       Foreground="#F8FAFC"
                       FontFamily="Segoe UI"/>
            <TextBlock Text="Select audio output"
                       FontSize="20"
                       Foreground="#94A3B8"
                       Margin="0,10,0,0"
                       FontFamily="Segoe UI"/>
        </StackPanel>

        <!-- Device List -->
        <ListBox Grid.Row="1"
                 x:Name="DeviceList"
                 Margin="48,0,48,0">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:AudioDeviceItem}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding Name}"
                                   FontSize="24"
                                   Foreground="#F8FAFC"
                                   FontFamily="Segoe UI"
                                   VerticalAlignment="Center"/>

                        <Border Grid.Column="1"
                                Background="#059669"
                                CornerRadius="4"
                                Padding="12,5"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsDefault, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Default"
                                       FontSize="14"
                                       Foreground="White"
                                       FontWeight="SemiBold"
                                       FontFamily="Segoe UI"/>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Volume -->
        <StackPanel Grid.Row="2" Margin="80,28,80,0">
            <DockPanel Margin="0,0,0,10">
                <TextBlock Text="Master Volume"
                           FontSize="18"
                           Foreground="#94A3B8"
                           FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="VolumeLabel"
                           DockPanel.Dock="Right"
                           FontSize="18"
                           Foreground="#F8FAFC"
                           FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>
            </DockPanel>
            <Slider x:Name="VolumeSlider"
                    Minimum="0" Maximum="100"
                    SmallChange="1" LargeChange="5"
                    Style="{StaticResource VolumeSliderStyle}"
                    ValueChanged="OnVolumeChanged"/>
        </StackPanel>

        <!-- Status + Footer -->
        <Grid Grid.Row="3" Margin="80,20,80,48">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="StatusText"
                       Grid.Row="0"
                       FontSize="18"
                       FontFamily="Segoe UI"
                       Margin="0,0,0,14"
                       Visibility="Collapsed"/>

            <TextBlock Grid.Row="1"
                       Text="↑ ↓  Navigate     ◄ ►  Volume     A / Enter  Select     B / Esc  Exit"
                       FontSize="16"
                       Foreground="#475569"
                       FontFamily="Segoe UI"/>
        </Grid>
    </Grid>
</Window>

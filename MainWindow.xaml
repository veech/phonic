<Window x:Class="phonic.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:phonic.Models"
        Title="Phonic"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#0F172A">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                Padding="48,22"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1E3A5F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="80,60,80,32">
            <TextBlock Text="Phonic"
                       FontSize="52"
                       FontWeight="Bold"
                       Foreground="#F8FAFC"
                       FontFamily="Segoe UI"/>
            <TextBlock Text="Select audio output"
                       FontSize="20"
                       Foreground="#94A3B8"
                       Margin="0,10,0,0"
                       FontFamily="Segoe UI"/>
        </StackPanel>

        <!-- Device List -->
        <ListBox Grid.Row="1"
                 x:Name="DeviceList"
                 Margin="48,0,48,0">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:AudioDeviceItem}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding Name}"
                                   FontSize="24"
                                   Foreground="#F8FAFC"
                                   FontFamily="Segoe UI"
                                   VerticalAlignment="Center"/>

                        <Border Grid.Column="1"
                                Background="#059669"
                                CornerRadius="4"
                                Padding="12,5"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsDefault, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Default"
                                       FontSize="14"
                                       Foreground="White"
                                       FontWeight="SemiBold"
                                       FontFamily="Segoe UI"/>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Status + Footer -->
        <Grid Grid.Row="2" Margin="80,20,80,48">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="StatusText"
                       Grid.Row="0"
                       FontSize="18"
                       FontFamily="Segoe UI"
                       Margin="0,0,0,14"
                       Visibility="Collapsed"/>

            <TextBlock Grid.Row="1"
                       Text="↑ ↓ / Stick  Navigate     A / Enter  Select     B / Esc  Exit"
                       FontSize="16"
                       Foreground="#475569"
                       FontFamily="Segoe UI"/>
        </Grid>
    </Grid>
</Window>
